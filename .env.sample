# Allmoxy SaaS Dashboard — environment variables
# Copy to `.env.local` for local dev. Phase 1 runs entirely on your Mac.

# --- Google Sheets service account -------------------------------------------
# Create at: https://console.cloud.google.com/iam-admin/serviceaccounts
# 1. Create a new service account (name: allmoxy-saas-dashboard-reader)
# 2. Create a JSON key, copy out the client_email and private_key
# 3. Share all Sheets listed in §5 of the project plan with the client_email as Viewer
GOOGLE_SA_CLIENT_EMAIL=allmoxy-saas-dashboard-reader@your-gcp-project.iam.gserviceaccount.com
# Private key must preserve newlines. Paste the key from the JSON file verbatim —
# server code re-hydrates real newlines from the literal \n sequences.
GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# --- Phase 1 API gate --------------------------------------------------------
# Shared-secret header gate until Google SSO lands in Phase 4. Any random string
# (generate with `openssl rand -hex 32`). Must match VITE_DASHBOARD_API_KEY below.
DASHBOARD_API_KEY=replace-me-with-32-random-bytes

# --- Frontend --------------------------------------------------------------
# Exposed to the browser — mirror DASHBOARD_API_KEY here. When we switch to
# Google SSO in Phase 4 this goes away entirely.
VITE_DASHBOARD_API_KEY=replace-me-with-32-random-bytes

# --- Server ------------------------------------------------------------------
# Express API port. Vite (on :3000) proxies /api/* here.
PORT=3001

# --- HubSpot Private App (for churn corpus extraction) ---------------------
# Create at: HubSpot Settings → Integrations → Private Apps → Create private app
# Required scopes:
#   crm.objects.companies.read
#   crm.objects.notes.read
#   crm.objects.deals.read
#   crm.objects.tickets.read
#   sales-email-read       (emails)
#   tickets                (tickets)
#   timeline               (engagements: calls, tasks, meetings)
# Copy the Access Token here. Used only by _etl_scripts/build_churn_corpus.mjs.
HUBSPOT_TOKEN=replace-me-with-your-hubspot-private-app-token

# --- JIRA Cloud (Implementation projects) ----------------------------------
# Used by _etl_scripts/sync_jira.mjs to pull the implementation issues behind
# the Advanced Roadmaps plan the service team coordinates in.
# Create an API token at:
#   https://id.atlassian.com/manage-profile/security/api-tokens
# Auth is HTTP Basic: base64("<email>:<api_token>"). Scope: read:jira-work.
JIRA_BASE=https://allmoxy.atlassian.net
JIRA_EMAIL=you@allmoxy.com
JIRA_API_TOKEN=replace-me-with-your-atlassian-api-token
# Advanced Roadmaps plan id behind the implementation timeline (from the URL:
# /jira/plans/<planId>/scenarios/...).
JIRA_PLAN_ID=314

# --- Harvest (time tracking) ------------------------------------------------
# Used by _etl_scripts/sync_harvest.mjs to pull clients, projects (with billing
# method: Hourly / Fixed Fee), and time entries — the services-revenue
# implementation hours. Create a Personal Access Token + find your Account ID:
#   https://id.getharvest.com/developers
HARVEST_ACCOUNT_ID=replace-me-with-your-harvest-account-id
HARVEST_TOKEN=replace-me-with-your-harvest-personal-access-token

# --- Feature flags ---------------------------------------------------------
# Show the P&L and QoE / Diligence groups (Profit & Loss, EBITDA Bridge,
# CIM Packet, Scorecard, Banker Handoff, Adjustments Register, Annual
# Amortization Evidence, Stripe ↔ QB Reconciliation, Invariant Tests,
# Definitions). Set to `true` in local dev so you keep full access for QoE
# prep work. Leave UNSET on Vercel production so the CS team doesn't see
# financial reporting. (Vite only exposes VITE_-prefixed env vars to the
# client.)
VITE_SHOW_FINANCIAL_TABS=true
