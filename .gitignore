# Source spreadsheets (raw xlsx with customer financial data — never commit)
_source_xlsx

# ETL cache (regeneratable — re-download via _etl_scripts/sync_hubspot.mjs etc.)
# Includes raw HubSpot API exports with stripe IDs and owner emails. Always
# stays local; ETL pulls fresh copies on demand.
_etl_scripts/cache

# Data snapshots — NEVER commit. Contain per-customer MRR, P&L, EBITDA, etc.
# Snapshots live on Beau's laptop and (eventually) Supabase Storage. The
# Vercel build will fetch them at deploy time, not from the repo.
public/snapshots

